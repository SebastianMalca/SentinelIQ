# 1. Base de datos PostgreSQL (Neon, Supabase o Local)
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/sentineliq"

# 2. URL de la aplicación (usualmente localhost en desarrollo)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 3. Stripe (Pagos y Suscripciones)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_BUSINESS="price_..."

# 4. Resend (Envío de correos para Alertas)
RESEND_API_KEY="re_..."

# 5. Seguridad (Cron Jobs y JWT Auth)
CRON_SECRET="cualquier_texto_largo_y_seguro"
NEXTAUTH_SECRET="cualquier_texto_largo_y_seguro_para_sesiones"
NEXTAUTH_URL="http://localhost:3000"
